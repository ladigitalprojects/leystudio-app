{
  "rules": {
    ".read": false,
    ".write": false,

    "data": {
      ".read": "auth != null && (auth.token.email === 'leonardoalvarado.jm@gmail.com' || auth.token.email === 'leylan.perdomo@gmail.com')",
      ".write": "auth != null && (auth.token.email === 'leonardoalvarado.jm@gmail.com' || auth.token.email === 'leylan.perdomo@gmail.com')"
    },

    "backups": {
      ".read": "auth != null && (auth.token.email === 'leonardoalvarado.jm@gmail.com' || auth.token.email === 'leylan.perdomo@gmail.com')",
      ".write": "auth != null && (auth.token.email === 'leonardoalvarado.jm@gmail.com' || auth.token.email === 'leylan.perdomo@gmail.com')"
    },

    "reservas": {
      "catalogo": { ".read": true,  ".write": "auth != null && (auth.token.email === 'leonardoalvarado.jm@gmail.com' || auth.token.email === 'leylan.perdomo@gmail.com')" },
      "config":   { ".read": true,  ".write": "auth != null && (auth.token.email === 'leonardoalvarado.jm@gmail.com' || auth.token.email === 'leylan.perdomo@gmail.com')" },
      "agenda":   { ".read": true,  ".write": "auth != null && (auth.token.email === 'leonardoalvarado.jm@gmail.com' || auth.token.email === 'leylan.perdomo@gmail.com')" },
      "solicitudes": {
        ".read": "auth != null && (auth.token.email === 'leonardoalvarado.jm@gmail.com' || auth.token.email === 'leylan.perdomo@gmail.com')",
        ".write": "auth != null && (auth.token.email === 'leonardoalvarado.jm@gmail.com' || auth.token.email === 'leylan.perdomo@gmail.com')",
        "$id": {
          ".write": "!data.exists() && newData.hasChildren(['nombre','tel','fecha','hora','servicios','total'])",
          "nombre": { ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length < 80" },
          "tel":    { ".validate": "newData.isString() && newData.val().length < 25" },
          "fecha":  { ".validate": "newData.isString() && newData.val().matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)" },
          "hora":   { ".validate": "newData.isString() && newData.val().matches(/^[0-9]{2}:[0-9]{2}$/)" },
          "nota":   { ".validate": "newData.isString() && newData.val().length < 250" },
          "img":    { ".validate": "newData.isString() && newData.val().length < 400000" }
        }
      }
    },

    "pub": {
      ".read": "auth != null && (auth.token.email === 'leonardoalvarado.jm@gmail.com' || auth.token.email === 'leylan.perdomo@gmail.com')",
      ".write": "auth != null && (auth.token.email === 'leonardoalvarado.jm@gmail.com' || auth.token.email === 'leylan.perdomo@gmail.com')",
      "$token": {
        ".read": true,
        "ficha": { ".write": true },
        "correo": { ".write": true, ".validate": "newData.isString() && newData.val().length < 120" },
        "ig": { ".write": true, ".validate": "newData.isString() && newData.val().length < 80" }
      }
    }
  }
}
