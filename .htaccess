RewriteEngine On

# Bloquear acceso a .git, .github y archivos ocultos
RedirectMatch 404 /\.git
RedirectMatch 404 /\.github

RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Bloquear archivos de configuración y datos de ejemplo
RedirectMatch 404 ^/firebase_rules\.json$
RedirectMatch 404 ^/leystudio_demo_data\.json$

# HTML siempre fresco: evita que el equipo trabaje con versiones viejas tras un deploy
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
